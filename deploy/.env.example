# Backend
BACKEND_PORT=9092
BACKEND_BUILD_TAGS=debug
SYSTEM_HOST=localhost
SYSTEM_PRIVATE_KEY=replace-with-openssl-rand-hex-32
SYSTEM_ADNL_PORT=16167
SYSTEM_LOG_LEVEL=0
SYSTEM_AUTH_SESSION_DURATION=24h
SYSTEM_STORE_HISTORY_DAYS=90
SYSTEM_UNPAID_FILES_LIFETIME=2h
SYSTEM_PAID_FILES_LIFETIME=72h
SYSTEM_UNPAID_FILES_LIFETIME_PUBLIC=15m
SYSTEM_TOTAL_DISK_SPACE_AVAILABLE=644245094400
SYSTEM_MAX_ALLOWED_SPAN_DAYS=7
SYSTEM_ADMIN_AUTH_TOKENS=

TON_CONFIG_URL=https://ton-blockchain.github.io/global.config.json

# Postgres (compose service "postgres"; DB_USER must stay pguser — db/init.sql)
DB_HOST=postgres
DB_PORT=5432
DB_USER=pguser
DB_PASSWORD=pgpassword
DB_NAME=storagedb
POSTGRES_PORT=5433

# tonutils-storage daemon
TONUTILS_STORAGE_VERSION=v1.5.1
TON_STORAGE_LOGIN=uClient
TON_STORAGE_PASSWORD=change-me-storage-api
TONUTILS_STORAGE_API_PORT=13474
TONUTILS_STORAGE_UDP_PORT=47431

# Metrics (optional)
NAMESPACE=ton-storage
SERVER_SUBSYSTEM=mtpo-server
BASIC_SUBSYSTEM=mtpo-db
